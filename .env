# Multi-Service Base URL Configuration
# ==========================================
# Define backend service URLs for all environments
# These are used automatically based on detected environment

# Auth Gateway URLs (handles /api/* endpoints: auth, register, password reset)
VITE_AUTH_GATEWAY_URL_DEV=https://dev-auth-gateway.colibrilearning.com
VITE_AUTH_GATEWAY_URL_TEST=https://test-auth-gateway.colibrilearning.com
VITE_AUTH_GATEWAY_URL_STAGE=https://stage-auth-gateway.colibrilearning.com
VITE_AUTH_GATEWAY_URL_PROD=https://auth-gateway.colibrilearning.com

# Global API URLs (handles /global/* endpoints: subsidiaries, global data)
VITE_GLOBAL_API_URL_DEV=https://dev-api-ms.colibrigroup.com
VITE_GLOBAL_API_URL_TEST=https://test-api-ms.colibrigroup.com
VITE_GLOBAL_API_URL_STAGE=https://stage-api-ms.colibrigroup.com
VITE_GLOBAL_API_URL_PROD=https://api-ms.colibrigroup.com

# Ecommerce API URLs (handles /core/ecommerce/* endpoints: cart, checkout, etc.)
VITE_ECOMMERCE_API_URL_DEV=https://dev-ecomm-api.colibrilearning.com
VITE_ECOMMERCE_API_URL_TEST=https://test-ecomm-api.colibrilearning.com
VITE_ECOMMERCE_API_URL_STAGE=https://stage-ecomm-api.colibrilearning.com
VITE_ECOMMERCE_API_URL_PROD=https://ecomm-api.colibrilearning.com

# Apple Sign In Client ID (Service ID from Apple Developer Console)
VITE_APPLE_CLIENT_ID=merchant.com.colibrigroup.testidentitywidget

# Google OAuth Client ID (from Google Cloud Console)
# Obtain from Google Cloud Console > APIs & Services > Credentials
# Required for Google sign-in to work — leave empty to disable Google login
VITE_GOOGLE_CLIENT_ID=849375884089-h48ld9g29evhpb7jdra5jn0bce4thnse.apps.googleusercontent.com

# Application Rendering Mode
# Set to "TEST" for standalone testing with BrowserRouter (uses Vite proxy)
# Set to "WEBCOMPONENT" for production web component deployment (direct API calls)
VITE_RENDER_MODE=WEBCOMPONENT